{
  "name": "anibalealvarezs/amazon-hub-driver",
  "description": "Amazon driver for the Hub ecosystem",
  "license": "MIT",
  "authors": [
    {
      "name": "Aníbal Álvarez",
      "email": "anibalealvarezs@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "anibalealvarezs/api-client-skeleton": "dev-main",
    "anibalealvarezs/api-driver-core": "dev-main",
    "anibalealvarezs/amazon-api": "dev-main",
    "symfony/http-foundation": "^6.0 || ^7.0",
    "psr/log": "^1.0 || ^2.0 || ^3.0"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../api-client-skeleton",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../api-driver-core",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../amazon-api-anibal",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "composer",
      "url": "https://satis.anibalalvarez.com/"
    }
  ],
  "autoload": {
    "psr-4": {
      "Anibalealvarezs\\AmazonHubDriver\\": "src/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": false
}
